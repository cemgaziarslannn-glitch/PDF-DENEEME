<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CGA - Hızlı Link Oluşturucu</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">
    <style>
        body { margin:0; font-family:'Montserrat', sans-serif; background: #0a0a0a; color:#fff; display: flex; justify-content: center; align-items: center; height: 100vh; }
        .upload-card { background: #151515; padding: 40px; border-radius: 30px; border: 2px solid #00d2ff; box-shadow: 0 0 30px rgba(0,210,255,0.2); text-align: center; width: 90%; max-width: 400px; }
        h2 { color: #00d2ff; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px; }
        .drop-zone { border: 2px dashed #333; padding: 30px; border-radius: 20px; cursor: pointer; transition: 0.3s; margin-bottom: 20px; }
        .drop-zone:hover { border-color: #00d2ff; background: rgba(0,210,255,0.05); }
        input[type="file"] { display: none; }
        .btn { background: #00d2ff; color: #000; padding: 15px 30px; border-radius: 12px; border: none; font-weight: bold; cursor: pointer; width: 100%; font-size: 16px; }
        #resultArea { margin-top: 25px; display: none; background: #222; padding: 15px; border-radius: 12px; border: 1px solid #444; }
        #linkOutput { color: #00d2ff; word-break: break-all; font-size: 14px; display: block; margin-bottom: 10px; }
        .copy-btn { background: #27ae60; color: white; padding: 8px; border-radius: 6px; font-size: 12px; cursor: pointer; border: none; }
        .status { font-size: 12px; color: #888; margin-top: 10px; }
    </style>
</head>
<body>

<div class="upload-card">
    <h2>LİNK OLUŞTUR</h2>
    <p style="font-size: 13px; color: #888;">PDF veya Resim seçin, anında linke çevirelim.</p>
    
    <label class="drop-zone" id="dropZone">
        <span id="fileStatus">📁 Dosya Seç veya Sürükle</span>
        <input type="file" id="fileInput">
    </label>

    <button class="btn" id="uploadBtn">LİNKİ OLUŞTUR 🚀</button>

    <div id="resultArea">
        <span id="linkOutput"></span>
        <button class="copy-btn" id="copyBtn">LİNKİ KOPYALA</button>
    </div>
    
    <p class="status" id="loadingStatus"></p>
</div>

<script>
    const fileInput = document.getElementById('fileInput');
    const uploadBtn = document.getElementById('uploadBtn');
    const resultArea = document.getElementById('resultArea');
    const linkOutput = document.getElementById('linkOutput');
    const copyBtn = document.getElementById('copyBtn');
    const loadingStatus = document.getElementById('loadingStatus');
    const fileStatus = document.getElementById('fileStatus');

    fileInput.onchange = () => {
        if(fileInput.files[0]) fileStatus.innerText = "✅ " + fileInput.files[0].name;
    };

    uploadBtn.onclick = async () => {
        const file = fileInput.files[0];
        if (!file) return alert("Önce dosya seç abi!");

        loadingStatus.innerText = "Buluta gönderiliyor... Lütfen bekle.";
        uploadBtn.disabled = true;

        const formData = new FormData();
        formData.append('file', file);

        try {
            // File.io ücretsiz API kullanıyoruz (Kayıt gerektirmez, kota yemez)
            const response = await fetch('https://file.io', {
                method: 'POST',
                body: formData
            });
            const data = await response.json();

            if (data.success) {
                linkOutput.innerText = data.link;
                resultArea.style.display = 'block';
                loadingStatus.innerText = "Link Hazır!";
            } else {
                alert("Hata oluştu, tekrar dene.");
            }
        } catch (error) {
            alert("Sistem meşgul, biraz sonra dene.");
        } finally {
            uploadBtn.disabled = false;
        }
    };

    copyBtn.onclick = () => {
        navigator.clipboard.writeText(linkOutput.innerText);
        copyBtn.innerText = "KOPYALANDI!";
        setTimeout(() => { copyBtn.innerText = "LİNKİ KOPYALA"; }, 2000);
    };
</script>

</body>
</html>